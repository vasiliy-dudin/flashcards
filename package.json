    "@vitejs/plugin-vue": "^6.0.7",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^10.0.0",
    "dexie": "^4.4.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
